# Allow the user 3 attempts to enter the correct password.
# Correct password: "secure123"
# If they get it right, print "Access granted!" and stop.
# If they use all 3 attempts, print "Account locked."
#
# Hint: Use a for loop with range(3) and break when correct.
correct_password = "secure123"
# Your code here
i = 0
while (i < 3):
    password = input("Enter password")
    i += 1
    if password == correct_password:
        print("Accesss granted")
        break
else:
    print("Access denied")
    
