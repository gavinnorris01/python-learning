# Calculate the average of VALID scores only.
# Valid scores are between 0 and 100 (inclusive).
scores = [85, -5, 92, 150, 78, 45, 200]
total = 0
count = 0
# Your loop with continue here
for score in scores:
    if ((score < 0) or (score > 100)):
        continue
    else:
        total += score
        count += 1
# Print the average
print(score / count)

# Process only words that meet ALL of these criteria:
# - Not empty
# - Longer than 2 characters
# - Does NOT start with 'x'
words = ["hi", "xerox", "", "python", "xy", "code", "x", "algorithm"]
# Print each valid word. Use continue for invalid ones.
for word in words:
    if (word == ""):
        continue
    elif (len(word) <= 2):
        continue
    elif (word[0] == "x"):
        continue
    else:
        print(word)